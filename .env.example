OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# 직결합 단계: PAI-Vision의 WS 서버 URL.
# 기본값(shared/constants.py)이 로컬용이므로 로컬 실행 시엔 비워둬도 됨.
# 원격 Vision 서버 사용 시에만 설정 (예: wss://vision.yeoun.org/ws/scenes)
# VISION_WS_URL=wss://vision.yeoun.org/ws/scenes

# Action Hub 도입 전까지 0 유지. 1로 설정하면 robot_command를 WS로 전송 시도.
ACTION_HUB_ENABLED=0
