# PAI-Language 환경 변수 샘플.
# 복사해서 실제 값으로 채운 뒤 사용:  cp .env.example .env
# (.env 는 .gitignore 로 추적 제외 — API 키 커밋 금지)

# ─── OpenAI (LLM 명령 파싱) ───────────────────────────────────────────────
# 필수. 본인 키로 교체. 커밋 금지.
OPENAI_API_KEY=sk-...
# 사용할 모델 (예: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ─── Vision 연동 (게이팅용 장면 수신) ─────────────────────────────────────
# PAI-Vision API 의 WebSocket 엔드포인트. overhead 캠 장면을 구독해 박스/대상
# 감지 게이팅에 사용. PAI-Vision 이 :8000 으로 떠 있어야 함.
VISION_WS_URL=ws://localhost:8000/ws/scenes?camera_id=overhead
